{
  "name": "@lambda-musika/musika",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "sideEffects": false,
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "build:lib": "tsc --build",
    "build:docs": "typedoc --options ./typedoc.config.ts",
    "lint": "pnpm run \"/^lint:.+$/\"",
    "lint:tsc": "tsc --build",
    "test": "vitest --typecheck",
    "clean": "rm -rf build dist",
    "clean:hard": "rm -rf build dist node_modules/.tmp/tsconfig.*.tsbuildinfo"
  },
  "dependencies": {
    "@lambda-musika/audio": "workspace:*"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.0",
    "jsdom": "^28.1.0",
    "typedoc": "^0.28.17",
    "typescript": "catalog:",
    "vitest": "catalog:"
  }
}
