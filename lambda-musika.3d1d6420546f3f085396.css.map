.left {
  position: absolute;
  left: 0;
}
.right {
  position: absolute;
  right: 0;
}
.icon-stack {
  position: relative;
  display: inline-block;
  width: 1em;
  height: 1em;
  line-height: 1em;
  vertical-align: middle;
}
.icon-stack-icon {
  left: 0;
  position: absolute;
  width: 100%;
  text-align: center;
  line-height: inherit;
}
.sans-serif {
  font: 16px Arial, 'Helvetica Neue', Helvetica, sans-serif;
}
.monospace {
  font: 14px 'Monaco', 'Menlo', 'Ubuntu Mono', 'Consolas', 'source-code-pro', monospace;
}
/* Components */
.Musika-App {
  height: 100%;
  display: flex;
  flex-direction: column;
}
.Musika-Player {
  background-color: #000;
  user-select: none;
  height: 2em;
  flex-shrink: 0;
  cursor: default;
}
.Musika-Player > :not(:last-child) {
  margin-right: 0.21em;
}
.Musika-Player button {
  width: 2em;
  height: 2em;
}
.Musika-Player input[type=range] {
  height: 0.8em;
  margin: 0 0.5em;
  cursor: pointer;
}
.Musika-Player .Musika-TimeSlider {
  height: 100%;
  display: inline-block;
  margin-left: 0.3em;
}
.Musika-Player .Musika-TimeSeeker {
  height: 100%;
  display: inline-block;
}
.Musika-Player .Musika-TimeSeeker input[type=time] {
  height: 100%;
  border: none;
  outline: none;
  -moz-appearance: textfield;
  padding: 0 0 0 1em;
  margin: 0px;
  width: 5em;
  vertical-align: top;
}
.Musika-Player .Musika-TimeSeeker input[type=time]::-webkit-inner-spin-button,
.Musika-Player .Musika-TimeSeeker input[type=time]::-webkit-outer-spin-button {
  -webkit-appearance: none;
  margin: 0;
}
.Musika-CPULoad {
  user-select: none;
  width: 100%;
  height: 0.73rem;
  background: linear-gradient(to right, #8df957 0%, #ff0 30%, #f99157 50%, #f2777a 100%);
  color: #fff;
  flex-shrink: 0;
  font-size: 8px;
  position: relative;
  cursor: default;
}
.Musika-CPULoad > .black {
  position: absolute;
  right: 0;
  height: 100%;
  background-color: #181818;
}
.Musika-CPULoad > .left,
.Musika-CPULoad > .right {
  text-shadow: 0px 0px 4px #000, 0px 0px 2px #000, 0px 0px 2px #000, 0px 0px 2px #000, 0px 0px 2px #000;
  margin: 0 2px;
}
.ace_editor {
  width: 100%;
  height: 100%;
  z-index: 0;
}
.ace_scroller,
.ace_gutter {
  padding-top: 0.1em;
}
.ace_gutter-active-line {
  margin-top: 0.1em;
}
.ace_scroller::before,
.ace_gutter::before,
.ace_scroller::after,
.ace_gutter::after {
  position: absolute;
  width: 100%;
  height: 1.5em;
  content: ' ';
  z-index: 1;
  pointer-events: none;
}
.ace_scroller::before,
.ace_gutter::before {
  top: 0;
  background: linear-gradient(to bottom, #000 0%, rgba(0,0,0,0.5) 1%, rgba(0,0,0,0.25) 30%, rgba(0,0,0,0.1) 60%, rgba(0,0,0,0) 100%);
}
.ace_scroller::after,
.ace_gutter::after {
  bottom: 0;
  background: linear-gradient(to top, #000 0%, rgba(0,0,0,0.5) 1%, rgba(0,0,0,0.25) 30%, rgba(0,0,0,0.1) 60%, rgba(0,0,0,0) 100%);
}
.error_widget,
.ace_error {
  cursor: default;
  user-select: none;
}
.panel-wrapper {
  flex-shrink: 0;
  z-index: 0;
}
.panel-wrapper .Musika-BottomBar {
  height: 1.6em;
  user-select: none;
  background-color: #2d2d2d;
}
.panel-wrapper .Musika-BottomBar > :not(:last-child) {
  margin-right: 0.21em;
  display: inline-block;
  height: 100%;
}
.panel-wrapper .Musika-BottomBar button,
.panel-wrapper .Musika-BottomBar select {
  height: 100%;
}
.panel-wrapper .Musika-BottomBar button i.fa:only-child {
  width: 1em;
  vertical-align: middle;
}
.panel-wrapper .Musika-BottomBar .github {
  height: 100%;
  font-size: 1.6em;
  color: #ccc;
}
.panel-wrapper .Musika-BottomBar .github:hover:not(:active) {
  color: #fbfbfb;
}
.panel-wrapper .Musika-BottomBar .github i {
  vertical-align: top;
}
.panel-wrapper .Musika-BottomBar .panel-container {
  position: relative;
  display: inline-block;
  height: 100%;
}
.panel-wrapper .Musika-BottomBar .panel {
  display: block;
  position: absolute;
  left: 0;
  z-index: -1;
  width: 30em;
  height: auto;
  padding: 0 1em 2em 1em;
  color: #fbfbfb;
  font: 16px Arial, 'Helvetica Neue', Helvetica, sans-serif;
  box-shadow: 0 0 26px 10px #181818;
  animation: slidein 0.3s cubic-bezier(0.675, -0.01, 0.68, 1.21) forwards;
  cursor: default;
}
.panel-wrapper .Musika-BottomBar .panel button {
  padding: 0.4em 1em;
  border: 1px solid rgba(251,251,251,0.5);
  font: 16px Arial, 'Helvetica Neue', Helvetica, sans-serif;
  font-size: 14px;
}
@-moz-keyframes slidein {
  from {
    bottom: -10em;
  }
  to {
    bottom: 0.6em;
  }
}
@-webkit-keyframes slidein {
  from {
    bottom: -10em;
  }
  to {
    bottom: 0.6em;
  }
}
@-o-keyframes slidein {
  from {
    bottom: -10em;
  }
  to {
    bottom: 0.6em;
  }
}
@keyframes slidein {
  from {
    bottom: -10em;
  }
  to {
    bottom: 0.6em;
  }
}



