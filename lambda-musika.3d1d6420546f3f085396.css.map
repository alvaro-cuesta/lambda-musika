/* General styles */
* {
  box-sizing: border-box;
}
html,
body,
#container {
  height: 100%;
  margin: 0;
  padding: 0;
  background-color: #2d2d2d;
  color: #ccc;
  font: 14px 'Monaco', 'Menlo', 'Ubuntu Mono', 'Consolas', 'source-code-pro', monospace;
  overflow: hidden;
}
select,
input,
button {
  border: none;
  outline: none;
  cursor: pointer;
}
button {
  color: #fbfbfb;
  font: 14px 'Monaco', 'Menlo', 'Ubuntu Mono', 'Consolas', 'source-code-pro', monospace;
}
a {
  color: #fbfbfb;
}
a:link {
  text-decoration: none;
}
a:hover {
  color: #ebebeb;
}
a:active {
  color: #fbfbfb;
}
li {
  line-height: 1.3em;
}
button.color-orange,
.color-orange button {
  background-color: #f99157;
}
button.color-orange .fa-inverse,
.color-orange button .fa-inverse {
  color: #f99157;
}
button:hover:not(:active).color-orange,
.color-orange button:hover:not(:active) {
  background-color: #e98147;
}
button:hover:not(:active).color-orange .fa-inverse,
.color-orange button:hover:not(:active) .fa-inverse {
  color: #e98147;
}
button:active.color-orange,
.color-orange button:active {
  background-color: #ffb177;
}
button:active.color-orange .fa-inverse,
.color-orange button:active .fa-inverse {
  color: #ffb177;
}
.color-orange .panel,
